# Supabase project URL for the public mobile client
EXPO_PUBLIC_SUPABASE_URL=

# Public / publishable Supabase key for Expo mobile
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps Android SDK key for standalone Android builds that render react-native-maps
EXPO_PUBLIC_ANDROID_GOOGLE_MAPS_API_KEY=

# Optional showcase toggles for social auth buttons.
# Set to true only when the provider is configured in Supabase Auth.
EXPO_PUBLIC_OAUTH_GOOGLE_ENABLED=false
EXPO_PUBLIC_OAUTH_FACEBOOK_ENABLED=false
EXPO_PUBLIC_OAUTH_APPLE_ENABLED=false

# Seeded fallback exploration district for local development
EXPO_PUBLIC_DEFAULT_AREA_LABEL=Downtown Chicago
EXPO_PUBLIC_DEFAULT_LATITUDE=41.882657
EXPO_PUBLIC_DEFAULT_LONGITUDE=-87.623304
EXPO_PUBLIC_DEFAULT_STATE_CODE=IL
